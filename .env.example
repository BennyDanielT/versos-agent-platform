# Copy to .env and adjust. Never commit real secrets.

# Postgres (matches docker-compose)
DATABASE_URL=postgresql+asyncpg://versos:versos@localhost:5432/versos

# S3 / LocalStack
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_ENDPOINT_URL=http://localhost:4566
S3_BUCKET=versos-media

# LLM — NVIDIA NIM. Required for the triage agent. Free key at https://build.nvidia.com
NVIDIA_API_KEY=
# Optional overrides (sensible defaults in app/config.py):
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# LangSmith tracing (optional, added later)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=versos-platform
